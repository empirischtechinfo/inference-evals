[Unit]
Description=vLLM OpenAI-compatible inference server (empirischtech)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=config.env
EnvironmentFile=api-key.env
Environment=HF_HUB_ENABLE_HF_TRANSFER=1
Environment=PYTHONUNBUFFERED=1
WorkingDirectory=/opt/inference
ExecStart=/opt/inference/.venv/bin/vllm serve ${MODEL_PATH} --served-model-name ${SERVED_MODEL_NAME} --host ${HOST} --port ${PORT} --max-model-len ${MAX_MODEL_LEN} --gpu-memory-utilization ${GPU_MEMORY_UTILIZATION} --tensor-parallel-size ${TENSOR_PARALLEL_SIZE} --quantization ${QUANTIZATION} --dtype ${DTYPE} --api-key ${VLLM_API_KEY}
Restart=on-failure
RestartSec=10
StandardOutput=append:/var/log/inference/vllm.log
StandardError=append:/var/log/inference/vllm.log
OOMScoreAdjust=-500
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target